{
  "name": "devbox-agent",
  "version": "0.1.0",
  "description": "Self-hosted, Kubernetes-native sandbox orchestration for AI coding agents.",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/galpha-ai/Alpha-devbox.git"
  },
  "keywords": [
    "ai-agent",
    "sandbox",
    "kubernetes",
    "claude",
    "orchestration"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "bash scripts/dev-web-local.sh",
    "dev:server": "tsx src/index.ts --config config.web-local.yaml",
    "dev:web-local": "bash scripts/dev-web-local.sh",
    "dev:chat-local": "DEVBOX_CONFIG_PATH=config.chat-local.yaml DEVBOX_LOCAL_ENV_FILES='.env .env.local .env.chat-local' bash scripts/dev-web-local.sh",
    "e2e:web-local": "npm --prefix frontend run e2e:local",
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:test": "npm --prefix frontend run test",
    "frontend:test:watch": "npm --prefix frontend run test:watch",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@slack/bolt": "^4.6.0",
    "ai": "^6.0.158",
    "better-sqlite3": "^11.8.1",
    "cron-parser": "^5.5.0",
    "grammy": "^1.39.3",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.0.18",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=20"
  }
}
