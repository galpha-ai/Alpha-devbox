assistant_name: Devbox
data_root: .devbox-local

container:
  runtime: docker
  image: devbox-runner:latest
  timeout: 5400000
  idle_timeout: 300000
  max_concurrent: 2
  max_output_size: 10485760

web:
  enabled: true
  port: 18092

agents:
  - name: localqa
    path: agents/localqa

channels:
  - id: "web:*"
    agents:
      - name: localqa
        requires_trigger: false

  # Slack channel or thread host channel.
  # Replace C0123456789 with your real Slack channel ID.
  - id: "slack:C0123456789"
    agents:
      - name: localqa
        trigger: "@Devbox"
        requires_trigger: true

  # Telegram group or supergroup.
  # Get the exact tg:... value by sending /chatid to the bot.
  - id: "tg:-1001234567890"
    agents:
      - name: localqa
        trigger: "@Devbox"
        requires_trigger: true

  # Telegram private messages.
  - id: "tg:user:*"
    agents:
      - name: localqa
        requires_trigger: false
