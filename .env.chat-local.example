# Copy to .env.chat-local and fill the chat credentials you want to enable.
# Loaded after .env and .env.local when running `npm run dev:chat-local`.

# Claude credential still comes from .env.local (or .env).
# Only add the chat tokens here.

SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...
TELEGRAM_BOT_TOKEN=123456789:telegram-bot-token
