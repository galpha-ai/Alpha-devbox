# Devbox Agent — local environment configuration
# Copy to .env.local, then fill ONE credential block below.

# ── Option 1: Anthropic API (direct) ──────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Option 2: Claude Code OAuth token ─────────────────────────
# CLAUDE_CODE_OAUTH_TOKEN=...

# ── Option 3: Google Vertex AI ────────────────────────────────
# CLAUDE_CODE_USE_VERTEX=1
# CLOUD_ML_REGION=us-east5
# ANTHROPIC_VERTEX_PROJECT_ID=your-gcp-project-id

# ── Option 4: Amazon Bedrock ─────────────────────────────────
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── Option 5: Third-party gateway (OpenRouter, LiteLLM, etc.) ─
# ANTHROPIC_API_KEY=your-gateway-key
# ANTHROPIC_BASE_URL=https://openrouter.ai/api/v1

# ── Optional ──────────────────────────────────────────────────
# ANTHROPIC_DEFAULT_SONNET_MODEL=claude-sonnet-4-5-20250929

# Recommended for local smoke runs
DEVBOX_DISABLE_SESSION_RESUME=1
DEVBOX_WEB_CLEAN=1

# Optional base URL used when TG/Slack replies suggest a richer Web replay view.
# Precedence:
# 1. DEVBOX_PUBLIC_WEB_BASE_URL
# 2. DEVBOX_FRONTEND_URL
# 3. default http://127.0.0.1:5175/
# DEVBOX_PUBLIC_WEB_BASE_URL=https://your-web-host.example.com/
# DEVBOX_FRONTEND_URL=http://127.0.0.1:5175/

# Optional chat tokens (not needed for web-only local demo)
# TELEGRAM_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=
