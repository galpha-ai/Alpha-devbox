# Local thesis web demo
# Copy to .env.local or .env, then fill one Claude credential.

# Required: choose one
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_CODE_OAUTH_TOKEN=...

# Optional: custom Anthropic-compatible proxy/base URL
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Recommended for local smoke runs
DEVBOX_DISABLE_SESSION_RESUME=1
DEVBOX_WEB_CLEAN=1

# Optional chat tokens (not needed for web-only local demo)
# TELEGRAM_BOT_TOKEN=
# SLACK_APP_TOKEN=
# SLACK_BOT_TOKEN=
